{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Garden Agent",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "garden-agent"
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Restart Garden Agent (pm2)",
      "type": "shell",
      "command": "npm run build && pm2 restart garden-agent",
      "problemMatcher": ["$tsc"],
      "group": "build"
    }
  ]
}
