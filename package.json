{
  "name": "garden-agent",
  "version": "0.1.0",
  "description": "AI gardening assistant — polls Telegram bot, processes via Claude Agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "pm2": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop garden-agent",
    "pm2:logs": "pm2 logs garden-agent",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
